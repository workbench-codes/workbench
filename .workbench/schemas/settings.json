{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Workbench Settings",
  "description": "Configuration for workbench project management and tooling",
  "type": "object",
  "properties": {
    "project_management": {
      "description": "The project management tool to use for issue tracking and workflow management",
      "type": "string",
      "enum": [
        "linear",
        "github-issues"
      ]
    },
    "orchestrator": {
      "description": "Settings for workflow orchestration behavior",
      "type": "object",
      "properties": {
        "strategy": {
          "description": "Default strategy used when answering non-critical sub-command questions",
          "type": "object",
          "properties": {
            "name": {
              "type": "string",
              "default": "minimum-changes-expandability"
            },
            "principles": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "minItems": 1,
              "default": [
                "minimum changes",
                "maximum expandability",
                "do not deliver what is not needed"
              ]
            }
          },
          "additionalProperties": false,
          "default": {
            "name": "minimum-changes-expandability",
            "principles": [
              "minimum changes",
              "maximum expandability",
              "do not deliver what is not needed"
            ]
          }
        },
        "escalation": {
          "description": "Controls when the orchestrator escalates questions to the user",
          "type": "object",
          "properties": {
            "escalate_on_blocking": {
              "type": "boolean",
              "default": true
            },
            "escalate_on_critical": {
              "type": "boolean",
              "default": true
            },
            "max_auto_answers_per_step": {
              "type": "integer",
              "minimum": 0,
              "default": 2
            }
          },
          "additionalProperties": false,
          "default": {
            "escalate_on_blocking": true,
            "escalate_on_critical": true,
            "max_auto_answers_per_step": 2
          }
        }
      },
      "additionalProperties": false,
      "default": {
        "strategy": {
          "name": "minimum-changes-expandability",
          "principles": [
            "minimum changes",
            "maximum expandability",
            "do not deliver what is not needed"
          ]
        },
        "escalation": {
          "escalate_on_blocking": true,
          "escalate_on_critical": true,
          "max_auto_answers_per_step": 2
        }
      }
    },
    "tools": {
      "description": "Centralised toggles for shared tools that agents may use",
      "type": "object",
      "properties": {
        "ck_semantic_search": {
          "description": "When false, suppresses use of ck semantic search across all agents",
          "type": "boolean",
          "default": true
        },
        "ck_hybrid_search": {
          "description": "When false, suppresses use of ck hybrid search across all agents",
          "type": "boolean",
          "default": true
        }
      },
      "additionalProperties": false,
      "default": {
        "ck_semantic_search": true,
        "ck_hybrid_search": true
      }
    },
    "sync": {
      "description": "Controls which files and directories are synced from the source workbench",
      "type": "object",
      "properties": {
        "paths": {
          "description": "Paths to sync from the source workbench (directories are merged, files are overwritten)",
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1,
          "default": [
            ".opencode",
            ".workbench/schemas",
            "README.md"
          ]
        }
      },
      "additionalProperties": false,
      "default": {
        "paths": [
          ".opencode",
          ".workbench/schemas",
          "README.md"
        ]
      }
    },
    "ticketer": {
      "description": "Settings for the ticketer workflow agent behavior",
      "type": "object",
      "properties": {
        "allow_decomposition": {
          "description": "When true, the ticketer may suggest breaking large issues into sub-issues during ticket creation",
          "type": "boolean",
          "default": true
        }
      },
      "additionalProperties": false,
      "default": {
        "allow_decomposition": true
      }
    }
  },
  "required": [
    "project_management"
  ],
  "additionalProperties": false
}
